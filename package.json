{
  "name": "evans-ibok-website",
  "private": true,
  "description": "Evans Ibok's Website",
  "version": "1.0.0",
  "author": "Evans Ibok <evansibok@gmail.com>",
  "engines": {
    "node": ">=18.x",
    "npm": ">=9.x",
    "yarn": ">=1.15"
  },
  "dependencies": {
    "bufferutil": "^4.1.0",
    "gatsby": "^5.16.1",
    "gatsby-plugin-image": "^3.16.0",
    "gatsby-plugin-manifest": "^5.16.0",
    "gatsby-plugin-offline": "^6.16.0",
    "gatsby-plugin-react-helmet": "^6.16.0",
    "gatsby-plugin-sharp": "^5.16.0",
    "gatsby-source-filesystem": "^5.16.0",
    "gatsby-transformer-sharp": "^5.16.0",
    "prop-types": "^15.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet": "^6.1.0",
    "react-icons": "^5.6.0",
    "typescript": "^6.0.2",
    "utf-8-validate": "^6.0.6"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "sass-loader": "^16.0.7"
  },
  "keywords": [
    "evansibok",
    "portfolio",
    "resume"
  ],
  "license": "MIT",
  "scripts": {
    "build": "gatsby clean && gatsby build",
    "develop": "gatsby develop",
    "format": "prettier --write \"**/*.{js,jsx,json,md}\"",
    "start": "gatsby clean && yarn run develop",
    "serve": "gatsby serve",
    "sass:watch": "cd src/ && sass --watch sass/app.scss css/app.css",
    "test": "echo \"Write tests! -> https://gatsby.dev/unit-testing\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/evansibok/evansibok"
  },
  "bugs": {
    "url": "https://github.com/evansibok/evansibok/issues"
  },
  "packageManager": "yarn@4.13.0"
}
